{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PersonEstimation",
  "type": "object",
  "properties": {
    "perceived_gender": {
      "type": "string",
      "enum": ["female", "male", "unknown"],
      "description": "Perceived gender presentation based on visible appearance."
    },
    "age_estimate": {
      "type": "integer",
      "minimum": 0,
      "maximum": 120,
      "description": "Estimated age of the person in years."
    },
    "perceived_ancestry_cluster": {
      "type": "string",
      "enum": [
        "West Eurasian",
        "East Asian",
        "South Asian",
        "Sub-Saharan African",
        "Native American",
        "Oceanian",
        "unknown"
      ],
      "description": "Perceived broad ancestry cluster based on visible appearance."
    },
    "eye_color": {
      "type": "string",
      "enum": [
        "brown",
        "hazel",
        "blue",
        "green",
        "amber",
        "gray",
        "unknown"
      ],
      "description": "Eye color of the person."
    },
    "beard_style": {
      "type": "string",
      "enum": [
        "n/a",
        "clean_shaven",
        "stubble_light",
        "stubble_heavy",
        "beard_full",
        "goatee",
        "mustache",
        "chinstrap",
        "van_dyke",
        "unknown"
      ],
      "description": "Visible beard style, if any. Use n/a when beard classification is not applicable."
    }
  },
  "required": ["perceived_gender", "age_estimate", "perceived_ancestry_cluster", "eye_color"]
}
